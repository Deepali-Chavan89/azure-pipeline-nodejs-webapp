{
    "name": "app-service-hello-world",
    "description": "Simple Hello World Node.js sample for Azure App Service",
    "version": "0.0.1",
    "private": true,
    "license": "MIT",
    "author": "Microsoft",
    "scripts": {
        "preinstall": "echo 'preinstall: before npm install'",
        "install": "echo 'install: during npm install'",
        "postinstall": "echo 'postinstall: after npm install'",
        "prestart": "echo 'prestart: before start'",
        "start": "node index.js",
        "poststart": "echo 'poststart: after start'",
        "dev": "node --watch index.js",
        "prebuild": "npm run lint",
        "build": "echo '✓ Build: validated and ready'",
        "postbuild": "echo '✓ Build complete'",
        "pretest": "echo 'Running tests against server...'",
        "test": "node test.js",
        "posttest": "echo '✓ All tests finished'",
        "prerestart": "echo 'prerestart: before restart'",
        "restart": "npm stop && npm start",
        "postrestart": "echo 'postrestart: after restart'",
        "prestop": "echo 'prestop: before stop'",
        "stop": "echo 'stop: stopping server'",
        "poststop": "echo 'poststop: after stop'",
        "prepack": "echo 'prepack: before packing'",
        "postpack": "echo 'postpack: after packing'",
        "prepublishOnly": "echo 'prepublishOnly: before publish'",
        "prepare": "echo 'prepare: post-install & before publish'",
        "preversion": "npm run lint && npm test",
        "version": "echo 'version: after version bump'",
        "postversion": "echo 'postversion: after version commit'",
        "release": "npm run build && npm test && npm version patch",
        "lint": "eslint .",
        "format": "prettier --single-quote --write *.js"
    },
    "devDependencies": {
        "eslint": "^7.5.0",
        "prettier": "^2.0.5"
    },
    "dependencies": {
        "body-parser": "^1.19.0",
        "cors": "^2.8.5",
        "express": "^4.22.1"
    },
    "engines": {
        "node": ">=10"
    }
}
